FROM python:3.12-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn[standard] \
    httpx \
    pydantic \
    python-multipart

# Copy controller code
COPY elyrii_ai/controller/controller.py /app/
COPY elyrii_ai/requirements.txt /app/

# Expose port
EXPOSE 8080

# Run controller
CMD ["python", "controller.py"]
