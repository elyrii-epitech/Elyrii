FROM python:3.12-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn[standard] \
    httpx \
    pydantic \
    python-multipart

# Copy controller code
COPY controller.py /app/
COPY requirements.txt /app/ 2>/dev/null || true

# Expose port
EXPOSE 8080

# Run controller
CMD ["python", "controller.py"]
