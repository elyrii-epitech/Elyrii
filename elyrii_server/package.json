{
  "name": "elyrii-server",
  "version": "1.0.0",
  "description": "Elyrii Server - Documentation and Workspace Management",
  "private": true,
  "workspaces": [
    "services/auth",
    "services/chat",
    "services/gateway"
  ],
  "scripts": {
    "docs": "bun run docs:build",
    "docs:build": "bun run docs:clean && bun run docs:generate",
    "docs:clean": "rm -rf docs/api",
    "docs:generate": "typedoc",
    "docs:auth": "cd services/auth && typedoc",
    "docs:chat": "cd services/chat && typedoc",
    "docs:gateway": "cd services/gateway && typedoc",
    "docs:serve": "bunx serve docs -p 8080"
  },
  "devDependencies": {
    "typedoc": "^0.25.13",
    "typedoc-plugin-markdown": "^3.17.1",
    "typescript": "^5.7.2"
  }
}
