{
  "name": "elyrii_server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch index.ts",
    "build": "bun build index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "prod": "bun run build && bun run start",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "docs:build": "cd scripts && ./generate-docs.sh build",
    "docs:serve": "cd scripts && ./generate-docs.sh serve"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-validator": "^0.7.6",
    "@neondatabase/serverless": "^1.0.2",
    "axios": "^1.14.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "hono-openapi": "^1.3.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.20.0",
    "quansync": "^1.0.0",
    "sqlite3": "^6.0.1",
    "zod": "^4.3.6"
  }
}
